#!/bin/sh

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

# If muted, print ´Üę  and exit.
[ "$vol" != "${vol%\[MUTED\]}" ] && echo ´Üę && exit

vol="${vol#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 70)) ) icon="´ÇĘ " ;;
	$((vol >= 30)) ) icon="´Çž " ;;
	$((vol >= 1))  ) icon="´ÇŽ " ;;
	* ) echo ´Üę && exit ;;
esac

echo "$icon$vol%"
