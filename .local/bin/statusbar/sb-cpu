#!/bin/sh

icon="Ôčõ"
color_b="$(xrdb -get color12)"
color_o="$(xrdb -get color11)"
color_p="$(xrdb -get color13)"
color_r="$(xrdb -get color9)"

case $BUTTON in
    1) notify-send -a "button" "Ôéź CPU hogs" "$(ps axch -o cmd:15,%cpu --sort=-%cpu | head)\\n(100% per core)" ;;
esac

# Get initial CPU temperature
get_temp() {
    echo $(( $(cat /sys/class/hwmon/hwmon*/temp1_input 2>/dev/null || echo 0) / 1000 ))
}

warning() {
    notify-send -u critical "$icon $1¬įC"
    command -v beeps >/dev/null && beeps -b warning
    echo -e "^c$color_r^$icon $1¬įC^d^"
    sleep 5s
}

temp=$(get_temp)

case $temp in
    [0-4][0-9]) color=$color_b;;    # Low  (00-49¬įC)
    [5-6][0-9]) color=$color_o;;    # Norm (50-69¬įC)
    [7-8][0-9]) color=$color_p;;    # High (70-89¬įC)
    [9-9][0-4]) color=$color_r;;    # High (90-94¬įC)
    *) while [[ $temp -ge 95 ]]; do # Crit (>= 95¬įC)
           warning $temp
           temp=$(get_temp)
       done;;
esac

echo -e "^c$color^$icon^d^ $temp¬įC"
